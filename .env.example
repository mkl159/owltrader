# Copie ce fichier en .env et renseigne tes valeurs (le .env n'est jamais commité).

# --- Obligatoire ---
TELEGRAM_BOT_TOKEN=

# --- Protection du bot (mot de passe à la 1re connexion ; vide = bot ouvert) ---
# Bot access password (asked once on first connection ; empty = open bot)
ACCESS_PASSWORD=133456789

# --- Optionnel : clés API GRATUITES (renforcent la robustesse, non requises) ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
NEWSAPI_API_KEY=

# --- Optionnel : IA pour résumer/noter les actualités (désactivée par défaut) ---
# Laisse vide pour utiliser l'analyse locale gratuite.
ANTHROPIC_API_KEY=

# --- Optionnel : conseiller IA OpenAI (avis acheter/vendre quotidien, commande /ia) ---
# Limites intégrées : 1 requête/jour, pas d'appel si aucune position ni bourse fermée.
# Optional OpenAI advisor (daily buy/sell advice, /ia command). 1 request/day max.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_MAX_TOKENS=100000

# --- Optionnel : Alpaca paper-trading (compte fictif via vraie API, gratuit) ---
# Compte gratuit sur alpaca.markets -> clés "Paper Trading". Commande bot : /alpaca
ALPACA_API_KEY_ID=
ALPACA_API_SECRET=

# --- Optionnel : échange crypto via ccxt (Binance, Kraken, Coinbase…). Commande : /broker ---
# Astuce : utilise le testnet/sandbox de l'échange pour t'entraîner sans risque.
EXCHANGE_NAME=
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Ces clés sont aussi réglables directement dans Telegram (/config, /set) — stockées chiffrées.
# These keys can also be set from Telegram (/config, /set) — stored encrypted.
